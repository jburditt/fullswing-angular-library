{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "fullswing-angular-library": {
      "projectType": "library",
      "root": "projects/fullswing-angular-library",
      "sourceRoot": "projects/fullswing-angular-library/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/fullswing-angular-library/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/fullswing-angular-library/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/fullswing-angular-library/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "projects/fullswing-angular-library/tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        }
      }
    },
    "fullswing-blog": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/fullswing-blog",
      "sourceRoot": "projects/fullswing-blog/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/fullswing-blog/src/main.ts",
            "tsConfig": "projects/fullswing-blog/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/fullswing-blog/public"
              }
            ],
            "styles": [
              "projects/fullswing-blog/src/styles.css",
              "node_modules/prismjs/themes/prism-okaidia.css",
              "node_modules/prismjs/plugins/line-numbers/prism-line-numbers.css",
              "node_modules/prismjs/plugins/line-highlight/prism-line-highlight.css",
              "node_modules/prismjs/plugins/command-line/prism-command-line.css"
            ],
            "scripts": [
              "node_modules/prismjs/prism.js",
              "node_modules/prismjs/components/prism-csharp.min.js",
              "node_modules/prismjs/components/prism-css.min.js",
              "node_modules/prismjs/components/prism-javascript.min.js",
              "node_modules/prismjs/components/prism-typescript.min.js",
              "node_modules/prismjs/components/prism-json.min.js",
              "node_modules/prismjs/components/prism-yaml.min.js",
              "node_modules/prismjs/plugins/line-numbers/prism-line-numbers.js",
              "node_modules/prismjs/plugins/line-highlight/prism-line-highlight.js",
              "node_modules/prismjs/plugins/command-line/prism-command-line.js",
              "node_modules/mermaid/dist/mermaid.min.js",
              "node_modules/clipboard/dist/clipboard.min.js"
            ],
            "server": "projects/fullswing-blog/src/main.server.ts",
            "outputMode": "server",
            "ssr": {
              "entry": "projects/fullswing-blog/src/server.ts"
            }
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "5MB",
                  "maximumError": "10MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "fullswing-blog:build:production"
            },
            "development": {
              "buildTarget": "fullswing-blog:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n"
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "tsConfig": "projects/fullswing-blog/tsconfig.spec.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/fullswing-blog/public"
              }
            ],
            "styles": [
              "projects/fullswing-blog/src/styles.css"
            ]
          }
        }
      }
    },
    "gamifyworkout": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/gamifyworkout",
      "sourceRoot": "projects/gamifyworkout/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/gamifyworkout/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "projects/gamifyworkout/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/gamifyworkout/public"
              }
            ],
            "styles": [
              "projects/gamifyworkout/src/styles.scss"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "gamifyworkout:build:production"
            },
            "development": {
              "buildTarget": "gamifyworkout:build:development"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "proxyConfig": "projects/gamifyworkout/src/proxy.conf.js"
          }
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n"
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "projects/gamifyworkout/tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/gamifyworkout/public"
              }
            ],
            "styles": [
              "projects/gamifyworkout/src/styles.scss"
            ]
          }
        }
      }
    },
    "angular-bootstrap": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/angular-bootstrap",
      "sourceRoot": "projects/angular-bootstrap/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "dist/angular-bootstrap"
            },
            "index": "projects/angular-bootstrap/src/index.html",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "projects/angular-bootstrap/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/angular-bootstrap/src/app/shared/template/assets",
                "output": "/assets/"
              },
              "projects/angular-bootstrap/src/favicon.ico",
              "projects/angular-bootstrap/src/assets"
            ],
            "styles": [
              "projects/angular-bootstrap/src/styles.scss",
              //"node_modules/survey-core/survey-core.min.css"
            ],
            "scripts": [],
            "browser": "projects/angular-bootstrap/src/main.ts"
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1mb",
                  "maximumError": "2mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "2kb",
                  "maximumError": "4kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "angular-bootstrap:build:production"
            },
            "development": {
              "buildTarget": "angular-bootstrap:build:development"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "proxyConfig": "projects/angular-bootstrap/src/proxy.conf.js",
            "ssl": true,
            "sslKey": "projects/angular-bootstrap/ssl/localhost.key",
            "sslCert": "projects/angular-bootstrap/ssl/localhost.crt"
          }
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "angular-bootstrap:build"
          }
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "tsconfig.spec.json",
            "assets": [
              "projects/angular-bootstrap/src/favicon.ico",
              "projects/angular-bootstrap/src/assets"
            ],
            "styles": [
              "src/styles.scss"
            ],
            "scripts": [],
            "karmaConfig": "karma.conf.js"
          }
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "angular-bootstrap:build",
            "compodoc": true,
            "compodocArgs": [
              "-e",
              "json",
              "-d",
              "."
            ],
            "port": 6006
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "angular-bootstrap:build",
            "compodoc": true,
            "compodocArgs": [
              "-e",
              "json",
              "-d",
              "."
            ],
            "outputDir": "storybook-static"
          }
        }
      }
    }
  }
}
